{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "items": {
      "type": "json"
    },
    "subtotal": {
      "type": "decimal"
    },
    "shipping": {
      "type": "decimal"
    },
    "tax": {
      "type": "decimal"
    },
    "total": {
      "type": "decimal"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ],
      "default": "pending",
      "required": true
    },
    "customer": {
      "type": "json",
      "required": true
    },
    "paymentMethod": {
      "type": "string"
    },
    "shippingAddress": {
      "type": "json"
    },
    "trackingNumber": {
      "type": "string"
    },
    "notes": {
      "type": "blocks"
    }
  }
}
